# Required
TELEGRAM_TOKEN=put-your-telegram-bot-token-here
GEMINI_API_KEY=put-your-gemini-api-key-here

# Model (default: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Rate limits
DAILY_LIMIT=20
BURST_LIMIT=5
GLOBAL_LIMIT=10000

# Database
DB_PATH=data/bepors.db

# Admins (comma-separated Telegram user IDs)
ADMIN_IDS=
# Hard-blocked user IDs (comma-separated)
BLOCKED_USER_IDS=

# Health endpoint
HEALTH_HOST=127.0.0.1
HEALTH_PORT=8088

# Prometheus metrics (optional)
METRICS_ENABLED=false
METRICS_SECRET=

# Log salt (leave empty to auto-generate and persist to data/.log_salt)
LOG_SALT=
